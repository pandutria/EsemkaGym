<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    android:fillViewport="true"
    tools:context=".ui.fragment.ManageMemberFragment">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <RelativeLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvMenu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Menu"
                android:fontFamily="sans-serif-medium"
                android:textSize="16sp"
                android:layout_marginLeft="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage Members"
                android:layout_centerInParent="true"
                android:fontFamily="sans-serif-black"
                android:textSize="18sp"/>

        </RelativeLayout>

        <LinearLayout
            android:id="@+id/menuLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_below="@id/header"
            android:layout_marginTop="20dp"
            android:layout_marginHorizontal="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Active Member"
                android:gravity="center"
                android:id="@+id/menuActive"
                android:textSize="14sp"
                android:paddingVertical="10dp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_member_unselected"/>

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Past Member"
                android:gravity="center"
                android:textSize="14sp"
                android:paddingVertical="10dp"
                android:id="@+id/menuPast"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_member_unselected"/>

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Pending Approval"
                android:gravity="center"
                android:textSize="14sp"
                android:paddingVertical="10dp"
                android:fontFamily="sans-serif-medium"
                android:id="@+id/menuPending"
                android:background="@drawable/bg_member_unselected"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/menuLayout"
            android:paddingTop="20dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/bg_search"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="160dp"
                    android:layout_height="45dp"
                    android:layout_marginHorizontal="10dp"
                    android:background="@null"
                    android:hint="Search Member"
                    android:textAlignment="center"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:drawableLeft="@drawable/search"/>

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:layout_width="match_parent"
                android:layout_marginVertical="10dp"
                android:layout_height="match_parent"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                android:orientation="vertical"
                android:id="@+id/rv"/>

        </LinearLayout>

    </RelativeLayout>
</androidx.core.widget.NestedScrollView>